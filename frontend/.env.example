VITE_API_URL=http://localhost:5000/api

# Google Maps Platform key – enable "Places API (New)" in Google Cloud Console.
# ➜ https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# For local dev you can allow all referrers; restrict to your domain in production.
# If you leave this blank the app will still fetch images via the backend proxy.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
